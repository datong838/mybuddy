    "@nx/esbuild": "20.8.4",
    "@nx/eslint": "20.8.4",
    "@nx/eslint-plugin": "20.8.4",
    "@nx/js": "20.8.4",
    "@nx/react": "20.8.4",
    "@nx/rollup": "20.8.4",
    "@nx/web": "20.8.4",
