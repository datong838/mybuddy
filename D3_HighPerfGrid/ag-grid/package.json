    "**/baseline-browser-mapping": "2.10.21"
  },
  "packageManager": "yarn@1.22.21",
  "lavamoat": {
    "allowScripts": {
      "@axe-core/cli>chromedriver#147.0.4": true,
      "@swc/core#1.15.30": true,
      "esbuild#0.28.0": true,
      "eslint-plugin-import-x>unrs-resolver#1.11.1": true,
      "nx#20.8.4": true,
      "rulesync>fastmcp>mcp-proxy>pipenet>tldjs#2.3.2": true,
      "tsx>esbuild#0.27.7": true,
      "vite>esbuild#0.21.5": true,
      "vite>sass>@parcel/watcher#2.5.1": true,
