    "sections": [
        {
            "id": "block_0bc8388be5eda92312da19c25f1d7b70",
            "type": "heroTBM",
            "modifiers": ["animated-hero"],
            "heading": "The Scheduling Component With Every Feature",
            "body_html": "<p>Bryntum Scheduler is a contemporary, high-throughput UI component that drops cleanly into every major JavaScript framework, including <a href=\"/products/react-scheduler/\">React</a>, <a href=\"/products/angular-scheduler/\">Angular</a> and <a href=\"/products/vue-scheduler/\">Vue</a>.</p>",
            "body_text": "Bryntum Scheduler is a contemporary, high-throughput UI component that drops cleanly into every major JavaScript framework, including React , Angular and Vue .",
            "ctas": [
                {
                    "text": "Browse Examples",
