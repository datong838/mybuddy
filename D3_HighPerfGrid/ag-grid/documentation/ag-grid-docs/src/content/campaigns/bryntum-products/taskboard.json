        {
            "id": "block_0284d081fe88dec979b28b8edc99b607",
            "type": "text-media",
            "modifiers": ["image", "added-shadow"],
            "eyebrow": "Familiar UX",
            "heading": "Lean on Instantly Familiar UX",
            "body_html": "<p class=\"p1\">Cut down on user admin with the Task Board’s welcoming, intuitive interactions:</p> <ul> <li>Confirm changes with <a href=\"/products/taskboard/examples/task-drag/\">confirmation dialogs</a></li> <li><a href=\"/products/taskboard/examples/scrolling/\">Auto-scroll to any swimlane or column</a> for fast navigation.</li> <li>Edit tasks in place with <a href=\"/products/taskboard/examples/simple-task-edit/\">inline editing</a>, or reach for the <a href=\"/products/taskboard/examples/task-edit/\">task editor</a> and <a href=\"/products/taskboard/examples/task-menu/\">context menu options</a>.</li> </ul>",
            "body_text": "Cut down on user admin with the Task Board’s welcoming, intuitive interactions: Confirm changes with confirmation dialogs Auto-scroll to any swimlane or column for fast navigation. Edit tasks in place with inline editing , or reach for the task editor and context menu options .",
