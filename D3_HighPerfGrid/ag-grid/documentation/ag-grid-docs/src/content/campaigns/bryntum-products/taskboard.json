    "sections": [
        {
            "id": "block_752dc716eb48d2f18b2d877ec8f9d45d",
            "type": "heroTBM",
            "modifiers": ["animated-hero"],
            "heading": "A Highly Flexible Kanban Board Component",
            "body_html": "<p>See and steer your work with the Bryntum Task Board. Written in modern JavaScript, our Kanban component drops cleanly into <a href=\"https://bryntum.com/products/react-task-board/\">React</a>, <a href=\"https://bryntum.com/products/angular-task-board/\">Angular</a> and <a href=\"https://bryntum.com/products/vue-task-board/\">Vue</a> apps.</p>",
            "body_text": "See and steer your work with the Bryntum Task Board. Written in modern JavaScript, our Kanban component drops cleanly into React , Angular and Vue apps.",
            "ctas": [
                {
                    "text": "Browse Examples",
                    "href": "/products/taskboard/examples",
                    "title": "Browse Examples"
                },
                {
                    "text": "Get the Trial",
                    "href": "/download/?product=taskboard",
                    "title": "Get the Trial"
                }
            ],
            "media": [
                {
                    "kind": "svg-file",
                    "src": "heroes/taskboard.svg"
                }
            ]
        },
        {
            "id": "block_agbryntum_partnership",
            "type": "partnership",
            "heading": "Your JavaScript stack just expanded",
            "body_html": "<p>Since our 2025 <a href=\"https://blog.ag-grid.com/ag-grid-and-bryntum-join-forces-to-strengthen-developer-tooling-for-modern-web-applications/\">partnership with Bryntum</a>, Bryntum Task Board sits alongside AG Grid for kanban-style task workflows, crafted by a similar team and held to the same bar.</p>",
            "body_text": "Since our 2025 partnership with Bryntum, Bryntum Task Board sits alongside AG Grid for kanban-style task workflows, crafted by a similar team and held to the same bar.",
            "logo_light_src": "/images/campaigns/bryntum-products/shared/ag-grid-x-bryntum-light.svg",
            "logo_dark_src": "/images/campaigns/bryntum-products/shared/ag-grid-x-bryntum-dark.svg",
            "logo_alt": "AG Grid x Bryntum partnership"
        },
        {
