        {
            "id": "block_b0ecec48d200798e5261d055bd3d0058",
            "type": "text-media",
            "modifiers": ["image", "added-shadow"],
            "eyebrow": "Component Library",
            "heading": "50+ Additional Widgets",
            "body_html": "<p class=\"p1\">Pick from a <a href=\"/products/taskboard/examples/kitchen-sink/\">broad set of UI elements</a> that quickly give your app a polished, professional feel:</p> <ul class=\"ul1\"> <li class=\"li1\">Drop in <strong>lists, menus, toggles, sliders and more</strong> alongside the Bryntum Calendar.</li> <li class=\"li1\">Cut clicks and searching to meet user needs faster.</li> <li class=\"li1\">Wire up widgets straightforwardly via our clear docs.</li> </ul>",
            "body_text": "Pick from a broad set of UI elements that quickly give your app a polished, professional feel: Drop in lists, menus, toggles, sliders and more alongside the Bryntum Calendar. Cut clicks and searching to meet user needs faster. Wire up widgets straightforwardly via our clear docs.",
            "links": [
