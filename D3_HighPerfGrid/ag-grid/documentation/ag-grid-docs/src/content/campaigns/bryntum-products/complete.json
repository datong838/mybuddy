            "type": "text-media",
            "modifiers": ["image", "added-shadow"],
            "eyebrow": "Pro Scheduler",
            "heading": "A Scheduler Built for Pros",
            "body_html": "<p>Scheduler Pro is our pro-grade scheduling product, handling inter-task dependencies, constraints and working-time calendars. Written in ES2020 &amp; TypeScript, it drops cleanly into any React, Angular or Vue app.</p>",
            "body_text": "Scheduler Pro is our pro-grade scheduling product, handling inter-task dependencies, constraints and working-time calendars. Written in ES2020 & TypeScript, it drops cleanly into any React, Angular or Vue app.",
