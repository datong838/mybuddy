        {
            "id": "block_20bf74698f4e9c691fa32da9577b475a",
            "type": "text-media",
            "modifiers": ["image", "reverse", "added-shadow"],
            "eyebrow": "Feature Set",
            "heading": "Capable and Flexible",
            "body_html": "<p class=\"p1\">Written in modern JavaScript (ES6+), the Bryntum Calendar runs lean and embeds without fuss. You get:</p> <ul> <li>Snappy performance, even on <a href=\"/products/calendar/examples/megadataset/\">huge datasets</a>.</li> <li>One-click exports to <a href=\"/products/calendar/examples/exporttoexcel/\">Excel</a>, <a href=\"/products/calendar/examples/exporttoics/\">ICS</a> and <a href=\"/products/calendar/examples/print/\">print</a> formats.</li> <li>Tunable date and time settings: <a href=\"/products/calendar/examples/shifted/\">begin days at 6 PM</a> or slice time into six-minute <a href=\"/products/calendar/examples/day-time-ticks/\">intervals</a>.</li> </ul>",
            "body_text": "Written in modern JavaScript (ES6+), the Bryntum Calendar runs lean and embeds without fuss. You get: Snappy performance, even on huge datasets . One-click exports to Excel , ICS and print formats. Tunable date and time settings: begin days at 6 PM or slice time into six-minute intervals .",
            "links": [
                {
                    "text": "huge datasets",
                    "href": "/products/calendar/examples/megadataset/"
                },
                {
                    "text": "Excel",
                    "href": "/products/calendar/examples/exporttoexcel/"
                },
                {
                    "text": "ICS",
                    "href": "/products/calendar/examples/exporttoics/"
                },
                {
                    "text": "print",
                    "href": "/products/calendar/examples/print/"
                },
                {
                    "text": "begin days at 6 PM",
                    "href": "/products/calendar/examples/shifted/"
                },
                {
                    "text": "intervals",
                    "href": "/products/calendar/examples/day-time-ticks/"
                }
            ],
