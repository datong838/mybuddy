        {
            "id": "block_43c64c3290d21de094d2e1bf6c8bb680",
            "type": "text-media",
            "modifiers": ["image", "reverse", "added-shadow"],
            "eyebrow": "Resource Views",
            "heading": "Resource-First Layout",
            "body_html": "<p class=\"p1\">Keep an eye on every teammate’s events at a glance:</p> <ul> <li>Spot whose events you’re looking at right away, <span style=\"font-weight: 400;\">thanks to</span> friendly avatars in the header.</li> <li>Drag and drop events to reassign them in a beat.</li> <li>Enjoy a tidy, welcoming layout.</li> </ul>",
            "body_text": "Keep an eye on every teammate’s events at a glance: Spot whose events you’re looking at right away, thanks to friendly avatars in the header. Drag and drop events to reassign them in a beat. Enjoy a tidy, welcoming layout.",
            "links": [],
