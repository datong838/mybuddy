        {
            "id": "block_0b3a2b388d8b3c162ad4de5e0fe504b2",
            "type": "text-media",
            "modifiers": ["video-file", "added-shadow"],
            "eyebrow": "Multiple Views",
            "heading": "Several Layouts",
            "body_html": "<p class=\"p1\">Flip between layouts to see tasks from a few angles. The Bryntum Calendar offers several views, including:</p> <ul class=\"ul1\"> <li class=\"li1\"><a href=\"/products/calendar/examples/basic/\">Day, Week, Month, Year and Agenda layouts</a></li> <li class=\"li1\"><a href=\"/products/calendar/examples/day-agenda/\">Day Agenda,</a> <a href=\"/products/calendar/examples/listview/\">Grid</a> layouts</li> <li class=\"li1\"><a href=\"/products/calendar/examples/dual-dayview/\">Dual-Day</a> layout</li> </ul>",
            "body_text": "Flip between layouts to see tasks from a few angles. The Bryntum Calendar offers several views, including: Day, Week, Month, Year and Agenda layouts Day Agenda, Grid layouts Dual-Day layout",
