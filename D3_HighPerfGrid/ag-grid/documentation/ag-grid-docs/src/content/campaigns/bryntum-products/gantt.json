        {
            "id": "block_344b68ae395fbdaeaf56fe3f1d5b57df",
            "type": "text-media",
            "modifiers": ["image", "reverse", "added-shadow"],
            "eyebrow": "Customisation",
            "heading": "Fully Flexible Tailoring",
            "body_html": "<p><span style=\"font-weight: 400;\">Shape the JavaScript Gantt chart to match your project’s look, feel and workflow:</span></p> <ul> <li aria-level=\"1\" style=\"font-weight: 400;\"><span style=\"font-weight: 400;\">Pick one of </span><a href=\"https://bryntum.com/products/gantt/examples/theme/\"><span style=\"font-weight: 400;\">five themes</span></a><span style=\"font-weight: 400;\">, or </span><a href=\"https://bryntum.com/products/gantt/examples/custom-theme/\"><span style=\"font-weight: 400;\">roll your own</span></a><span style=\"font-weight: 400;\">.</span></li> <li aria-level=\"1\" style=\"font-weight: 400;\"><span style=\"font-weight: 400;\">Tailor taskbar </span><a href=\"https://bryntum.com/products/gantt/examples/taskstyles/\"><span style=\"font-weight: 400;\">styles</span></a><span style=\"font-weight: 400;\">, </span><a href=\"https://bryntum.com/products/gantt/examples/custom-rendering/\"><span style=\"font-weight: 400;\">content</span></a><span style=\"font-weight: 400;\"> and </span><a href=\"https://bryntum.com/products/gantt/examples/custom-taskbar/\"><span style=\"font-weight: 400;\">labels</span></a><span style=\"font-weight: 400;\">.</span></li> <li aria-level=\"1\" style=\"font-weight: 400;\"><span style=\"font-weight: 400;\">Add richly styled </span><a href=\"https://bryntum.com/products/gantt/examples/tooltips/\"><span style=\"font-weight: 400;\">custom tooltips</span></a><span style=\"font-weight: 400;\">.</span></li> <li class=\"p1\"><span style=\"font-weight: 400;\">Drop in a </span><a href=\"https://bryntum.com/products/gantt/examples/resourceassignment/\"><span style=\"font-weight: 400;\">bespoke assignment picker</span></a><span style=\"font-weight: 400;\"> for fast task delegation.</span></li> </ul>",
            "body_text": "Shape the JavaScript Gantt chart to match your project’s look, feel and workflow: Pick one of five themes , or roll your own . Tailor taskbar styles , content and labels . Add richly styled custom tooltips . Drop in a bespoke assignment picker for fast task delegation.",
