                    "src_original": "https://bryntum.com/wp-content/uploads/2022/05/schedulerpro-resourcehistogram-svalbard-2-scaled.png"
                }
            ]
        },
        {
            "id": "block_b27deebef856877e482370a5bc9b1a9a",
            "type": "text-media",
            "modifiers": ["video-file", "reverse", "added-shadow"],
            "eyebrow": "Smart Assignment",
            "heading": "Assign Tasks by Skill",
            "body_html": "<p>Let Scheduler Pro handle the logic behind the scenes so planning stays efficient:</p> <ul> <li>Match the right tasks with the right people without fuss.</li> <li>Pair tasks with teammates based on skills and availability.</li> <li>Auto-schedule tasks or drag them into suggested time slots.</li> </ul>",
            "body_text": "Let Scheduler Pro handle the logic behind the scenes so planning stays efficient: Match the right tasks with the right people without fuss. Pair tasks with teammates based on skills and availability. Auto-schedule tasks or drag them into suggested time slots.",
            "links": [],
            "ctas": [
                {
                    "text": "Open demo",
                    "href": "/products/schedulerpro/examples/skill-matching/",
                    "title": "Open demo"
                }
            ],
            "media": [
                {
                    "kind": "video",
                    "src": "../assets/schedulerpro/schedulerpro-skill-matching-zoom.mp4.mp4",
                    "src_original": "https://bryntum.com/wp-content/uploads/2022/05/schedulerpro-skill-matching-zoom.mp4.mp4"
                }
            ]
        },
        {
            "id": "block_db9616ac89f5620c3b5018eb7d1c9498",
            "type": "text-media",
            "modifiers": ["image", "added-shadow"],
            "eyebrow": "Auto-Scheduling",
            "heading": "Adaptive, Smarter Planning",
            "body_html": "<p class=\"p1\">Plan with confidence for real-world conditions:</p> <ul> <li aria-level=\"1\" style=\"font-weight: 400;\"><span style=\"font-weight: 400;\">Spot peak activity windows and overloaded categories via the heatmap.</span></li> <li aria-level=\"1\" style=\"font-weight: 400;\"><span style=\"font-weight: 400;\">Lean on </span><a href=\"https://bryntum.com/products/schedulerpro/examples/nested-events-dependencies/\"><span style=\"font-weight: 400;\">nested events</span></a> to make related-task handling simpler.</li> <li aria-level=\"1\" style=\"font-weight: 400;\"><a href=\"https://bryntum.com/products/schedulerpro/examples/travel-time/\"><span style=\"font-weight: 400;\">Factor travel time in</span></a><span style=\"font-weight: 400;\"> for tighter callout and field-routing planning.</span></li> <li><span style=\"font-weight: 400;\">Settle </span><a href=\"https://bryntum.com/products/schedulerpro/examples/conflicts/\"><span style=\"font-weight: 400;\">scheduling conflicts</span></a><span style=\"font-weight: 400;\"> and keep the schedule intact.</span></li> </ul>",
            "body_text": "Plan with confidence for real-world conditions: Spot peak activity windows and overloaded categories via the heatmap. Lean on nested events to make related-task handling simpler. Factor travel time in for tighter callout and field-routing planning. Settle scheduling conflicts and keep the schedule intact.",
            "links": [
                {
                    "text": "nested events",
                    "href": "https://bryntum.com/products/schedulerpro/examples/nested-events-dependencies/"
                },
