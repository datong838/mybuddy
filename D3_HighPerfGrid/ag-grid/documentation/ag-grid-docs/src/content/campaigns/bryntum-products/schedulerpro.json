    "sections": [
        {
            "id": "block_67e17f6b1228d9d75851bddbf1df0ace",
            "type": "heroTBM",
            "modifiers": ["animated-hero"],
            "heading": "A Pro-Grade Scheduling Component",
            "body_html": "<p class=\"p1\">Bryntum Scheduler Pro is a JavaScript UI component built for precise planning. It accounts for resource availability, dependencies and constraints out of the box.</p>",
            "body_text": "Bryntum Scheduler Pro is a JavaScript UI component built for precise planning. It accounts for resource availability, dependencies and constraints out of the box.",
