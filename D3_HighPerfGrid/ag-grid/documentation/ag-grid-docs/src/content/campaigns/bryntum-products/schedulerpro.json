        {
            "id": "block_568e2c365c073264165eb83fbaa79716",
            "type": "text-media",
            "modifiers": ["image", "added-shadow"],
            "eyebrow": "Customisation",
            "heading": "Style It However You Like",
            "body_html": "<p class=\"p1\">Make the scheduler feel on-brand with flexible styling controls.</p> <ul> <li class=\"p1\">Adjust our built-in themes via CSS variables, no fuss.</li> <li class=\"p1\">Roll your own custom theme.</li> <li class=\"p1\">Pick from preconfigured taskbar styles and colour sets.</li> </ul>",
            "body_text": "Make the scheduler feel on-brand with flexible styling controls. Adjust our built-in themes via CSS variables, no fuss. Roll your own custom theme. Pick from preconfigured taskbar styles and colour sets.",
