        {
            "id": "block_agbryntum_partnership",
            "type": "partnership",
            "heading": "Your JavaScript stack just expanded",
            "body_html": "<p>Since our 2025 <a href=\"https://blog.ag-grid.com/ag-grid-and-bryntum-join-forces-to-strengthen-developer-tooling-for-modern-web-applications/\">partnership with Bryntum</a>, Bryntum Scheduler Pro sits alongside AG Grid for dependency-aware scheduling and resource planning, crafted by a similar team and held to the same bar.</p>",
            "body_text": "Since our 2025 partnership with Bryntum, Bryntum Scheduler Pro sits alongside AG Grid for dependency-aware scheduling and resource planning, crafted by a similar team and held to the same bar.",
            "logo_light_src": "/images/campaigns/bryntum-products/shared/ag-grid-x-bryntum-light.svg",
            "logo_dark_src": "/images/campaigns/bryntum-products/shared/ag-grid-x-bryntum-dark.svg",
            "logo_alt": "AG Grid x Bryntum partnership"
        },
        {
