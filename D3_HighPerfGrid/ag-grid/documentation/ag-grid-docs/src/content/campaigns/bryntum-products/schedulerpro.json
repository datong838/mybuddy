        {
            "id": "block_e81c12ec56ed0ff49bce53b58de2f4c3",
            "type": "text-media",
            "modifiers": ["image", "reverse", "added-shadow"],
            "eyebrow": "Component Library",
            "heading": "50+ Additional Widgets",
            "body_html": "<p class=\"p1\">Pick from a <a href=\"/products/scheduler/examples/kitchen-sink/\">broad set of UI elements</a> that quickly give your app a polished, professional feel:</p> <ul class=\"ul1\"> <li class=\"li1\">Drop in <strong>buttons, menus, toggles, charts and more </strong>alongside Bryntum Scheduler Pro.</li> <li class=\"li1\">Cut clicks and searching to meet user needs faster.</li> <li class=\"li1\">Wire up widgets straightforwardly via our clear docs.</li> </ul>",
            "body_text": "Pick from a broad set of UI elements that quickly give your app a polished, professional feel: Drop in buttons, menus, toggles, charts and more alongside Bryntum Scheduler Pro. Cut clicks and searching to meet user needs faster. Wire up widgets straightforwardly via our clear docs.",
