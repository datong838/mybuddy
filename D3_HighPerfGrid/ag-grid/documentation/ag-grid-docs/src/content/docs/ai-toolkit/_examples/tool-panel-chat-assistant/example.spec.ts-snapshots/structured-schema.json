                        "enum": [
                          "date"
                        ]
                      },
                      "type": {
                        "type": "string",
                        "description": "Date filter operation type",
                        "enum": [
                          "equals",
                          "notEqual",
                          "lessThan",
                          "greaterThan",
                          "inRange",
                          "blank",
                          "notBlank"
                        ]
                      },
                      "dateFrom": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "Primary date filter value in YYYY-MM-DD HH:mm:ss format",
                        "pattern": "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}$"
                      },
                      "dateTo": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "Secondary date filter value for range operations in YYYY-MM-DD HH:mm:ss format",
                        "pattern": "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}$"
                      }
                    }
