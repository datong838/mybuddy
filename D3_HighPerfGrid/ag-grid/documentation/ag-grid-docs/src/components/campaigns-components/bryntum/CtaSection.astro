---
import { decorateBryntumHtml } from '@utils/bryntumCampaignAssets';

import BryntumCtaList from './BryntumCtaList.astro';
import type { BryntumTextButtonSection } from './types';
import styles from '../BryntumCampaign.module.scss';

interface Props {
    section: BryntumTextButtonSection;
}

const { section } = Astro.props;
---

<section class:list={[styles.ctaOuter, styles.sectionBgSecondary]}>
    <div class:list={[styles.sectionInner, styles.ctaSection]}>
        {section.eyebrow && <span class={styles.sectionEyebrow}>{section.eyebrow}</span>}
        {section.heading && <h2>{section.heading}</h2>}
        {/* body_html is treated as trusted content sourced from curated *-original.json files. */}
        {section.body_html && <div set:html={decorateBryntumHtml(section.body_html)} />}

        {
            section.ctas && (
                <BryntumCtaList
                    ctas={section.ctas}
                    buttonClass={['button', 'button-tertiary']}
                    wrapperClass={styles.ctaButtons}
                />
            )
        }
    </div>
</section>
