---
import { LicenseSetup } from '@components/license-setup/components/LicenseSetup';
import { getFrameworkFromPath } from '@components/docs/utils/urlPaths';
import { getEntry, type CollectionEntry } from 'astro:content';

const { pathname } = Astro.url;
const framework = getFrameworkFromPath(pathname);
const { data: seedRepos } = (await getEntry('seedProjects', 'grid-seed-projects')) as CollectionEntry<'seedProjects'>;
---

{
    /* SSR enabled because this component ha code samples that we want to appear in static HTML to be indexed by Algolia */
}
<LicenseSetup client:load library="grid" framework={framework} path={pathname} seedRepos={seedRepos} />
