---
/**
 * Angular Data Grid Landing Page
 *
 * Content is defined in: src/content/landing-pages/angular-data-grid.json
 */

import LandingPage from '@components/landing-pages/LandingPage.astro';
import { getEntry } from 'astro:content';

const contentEntry = await getEntry('landingPages', 'angular-data-grid');
const versionsEntry = await getEntry('versions', 'ag-grid-versions');

const content = contentEntry?.data;
const versions = versionsEntry?.data;
---

{content && <LandingPage content={content} versions={versions} />}
