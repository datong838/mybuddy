{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "plugins": ["./plugins/ag-grid-task-autogen"],
  "affected": {
    "defaultBase": "latest"
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "defaultExcludes": [
      "buildOutputExcludes",
      "!{projectRoot}/.eslintrc.*",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
      "!{projectRoot}/**/test/**",
      "!{projectRoot}/**/__image_snapshots__/**",
      "!{projectRoot}/tsconfig.spec.json"
    ],
    "buildOutputExcludes": ["!{projectRoot}/dist/**"],
    "production": [
      "default",
      "defaultExcludes",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
      "!{projectRoot}/tsconfig.spec.json"
    ],
    "tsDeclarations": [
      {
        "dependentTasksOutputFiles": "**/*.d.ts",
        "transitive": false
      }
    ],
    "jsOutputs": [
      {
        "dependentTasksOutputFiles": "**/*.js",
        "transitive": false
      }
    ],
    "styleOutputs": [
      {
        "dependentTasksOutputFiles": "**/*.*css",
        "transitive": false
      }
    ],
    "allOutputs": [
      {
        "dependentTasksOutputFiles": "**/*",
        "transitive": false
      }
    ],
    "allTransitiveOutputs": [
      {
        "dependentTasksOutputFiles": "**/*",
        "transitive": true
      }
    ],
    "tsDefaults": [
      "{projectRoot}/package.json",
      "{projectRoot}/src/**/*",
      "{projectRoot}/tsconfig.*.json",
      "tsDeclarations",
      "sharedGlobals",
      "defaultExcludes",
      {
        "externalDependencies": ["npm:typescript", "npm:esbuild"]
      }
    ],
    "sharedGlobals": ["{workspaceRoot}/esbuild.config*.cjs", "{workspaceRoot}/tsconfig.*.json"],
    "charts": ["chartsPackages", "chartsTypes"],
    "chartsPackages": [
      {
        "externalDependencies": ["ag-charts-locale", "ag-charts-community", "ag-charts-enterprise"]
      },
      {
        "runtime": "date -r ./node_modules/ag-charts-locale/dist \"+%Y-%m-%d %H:%M:%S\""
      },
      {
        "runtime": "date -r ./node_modules/ag-charts-community/dist \"+%Y-%m-%d %H:%M:%S\""
      },
      {
        "runtime": "date -r ./node_modules/ag-charts-enterprise/dist \"+%Y-%m-%d %H:%M:%S\""
      }
    ],
    "chartsTypes": [
      {
        "externalDependencies": ["ag-charts-types", "ag-charts-locale", "ag-charts-community", "ag-charts-enterprise"]
      },
      {
        "runtime": "date -r ./node_modules/ag-charts-locale/dist \"+%Y-%m-%d %H:%M:%S\""
      },
      {
        "runtime": "date -r ./node_modules/ag-charts-types/dist \"+%Y-%m-%d %H:%M:%S\""
      },
      {
        "runtime": "date -r ./node_modules/ag-charts-community/dist \"+%Y-%m-%d %H:%M:%S\""
      },
      {
        "runtime": "date -r ./node_modules/ag-charts-enterprise/dist \"+%Y-%m-%d %H:%M:%S\""
      }
    ]
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "cache": true
    },
    "build:types": {
      "dependsOn": ["^build:types"],
      "inputs": ["production", "^production"],
      "cache": true
    },
    "build:test": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build:types", "build:types"],
      "inputs": ["default", "buildOutputExcludes", "^production"],
      "outputs": [],
      "cache": true,
      "options": {
        "command": "npx tsc -p {projectRoot}/tsconfig.spec.json --noEmit"
      }
    },
    "build:package": {
      "dependsOn": ["^build:package"],
      "inputs": ["production", "^production"],
      "cache": true
    },
    "build:umd": {
      "dependsOn": ["build:package", "^build:package"],
      "inputs": ["^jsOutputs"],
      "cache": true
    },
    "build:styles": {
      "dependsOn": ["^build:styles"],
      "inputs": ["production", "^production"],
      "cache": true
    },
    "lint": {
      "inputs": ["default", "{workspaceRoot}/eslint.config.mjs", "{workspaceRoot}/yarn.lock"],
      "cache": true
    },
    "lint:depcruise": {
      "executor": "nx:run-commands",
      "inputs": ["{projectRoot}/src/**", "{projectRoot}/.dependency-cruiser.js"],
      "outputs": [],
      "cache": true,
      "options": {
        "cwd": "{projectRoot}",
        "commands": ["npx depcruise src"]
      }
    },
    "test": {
      "inputs": ["default", "buildOutputExcludes", "^production"],
      "outputs": [],
      "cache": true
    },
    "e2e": {
      "inputs": ["default", "buildOutputExcludes", "^production"],
      "outputs": [],
      "cache": true
    },
    "pack": {
      "inputs": ["allTransitiveOutputs", "{projectRoot}/.npmignore"],
      "cache": true
    },
    "nx:noop": {
      "cache": true,
      "inputs": [],
      "outputs": []
    },
    "nx:run-script": {
      "cache": true,
      "inputs": ["production"],
      "outputs": []
    },
    "nx:run-commands": {
      "cache": true
    },
    "@nx/jest:jest": {
      "cache": true,
      "options": {
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true
        }
      }
    }
  },
  "defaultProject": "all",
  "useLegacyCache": false
}
