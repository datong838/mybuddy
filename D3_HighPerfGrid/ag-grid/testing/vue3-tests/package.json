{
  "name": "ag-grid-vue3-tests",
  "private": true,
  "version": "36.0.0-beta.20260713.1111",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "start-server": "vite preview > http.log 2>&1 & echo $! > pid",
    "stop-server": "kill $(cat pid) 2>/dev/null; rm -f pid",
    "playwright": "npx playwright test --reporter=list",
    "test:e2e": "run-s -c start-server playwright stop-server",
    "preview": "vite preview --host"
  },
  "dependencies": {
    "vue": "^3.5.32",
    "vue-router": "^5.0.6",
    "ag-grid-community": "36.0.0-beta.20260713.1111",
    "ag-grid-enterprise": "36.0.0-beta.20260713.1111",
    "ag-grid-vue3": "36.0.0-beta.20260713.1111",
    "decimal.js": "^10.6.0"
  },
  "devDependencies": {
    "@mobileaction/action-kit": "^1.58.16",
    "playwright": "^1.59.1",
    "@playwright/test": "^1.59.1",
    "vite": "^6.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "typescript": "~5.8.3",
    "vue-tsc": "^3.2.7",
    "npm-run-all": "^4.1.5"
  }
}
