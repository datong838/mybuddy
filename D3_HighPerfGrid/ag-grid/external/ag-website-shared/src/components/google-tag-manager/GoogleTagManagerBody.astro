---
import { getIsStaging } from '@utils/env';

interface Props {
    googleTagManagerId: string;
    googleTagManagerAuth: string;
    googleTagManagerPreview: string;
}

const { googleTagManagerId, googleTagManagerAuth, googleTagManagerPreview } = Astro.props as Props;
const extraParams = getIsStaging() ? `&gtm_auth=${googleTagManagerAuth}&gtm_preview=${googleTagManagerPreview}` : '';
---

<noscript>
    <iframe
        src={`https://www.googletagmanager.com/ns.html?id=${googleTagManagerId}${extraParams}&gtm_cookies_win=x`}
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe>
</noscript>
