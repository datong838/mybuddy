{
  "name": "@ag-grid-community/locale",
  "version": "36.0.0-beta.20260713.1111",
  "description": "Localisation Module for AG Grid, providing translations in 31 languages.",
  "main": "./dist/package/main.cjs.js",
  "types": "./dist/types/src/main.d.ts",
  "module": "./dist/package/main.esm.mjs",
  "exports": {
    ".": {
      "import": "./dist/package/main.esm.mjs",
      "types": "./dist/types/src/main.d.ts",
      "require": "./dist/package/main.cjs.js",
      "default": "./dist/package/main.cjs.js"
    },
    "./*.js": {
      "import": "./dist/package/*.esm.mjs",
      "types": "./dist/types/src/*.d.ts",
      "require": "./dist/package/*.cjs.js",
      "default": "./dist/package/*.cjs.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ag-grid/ag-grid.git"
  },
  "keywords": [],
  "author": "AG Grid <info@ag-grid.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ag-grid/ag-grid/issues"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie >= 0",
    "not ie_mob >= 0",
    "not blackberry > 0",
    "not op_mini all",
    "not operamobile >= 0"
  ],
  "homepage": "https://www.ag-grid.com/",
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "typescript": "~5.8.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
