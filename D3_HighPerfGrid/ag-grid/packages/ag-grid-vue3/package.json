{
  "name": "ag-grid-vue3",
  "description": "AG Grid Vue 3 Component",
  "version": "36.0.0-beta.20260713.1111",
  "author": "Sean Landsman <sean@thelandsmans.com>",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ag-grid/ag-grid.git"
  },
  "bugs": {
    "url": "https://github.com/ag-grid/ag-grid/issues"
  },
  "homepage": "https://www.ag-grid.com/",
  "keywords": [
    "grid",
    "data",
    "table",
    "vue",
    "vuejs"
  ],
  "main": "./dist/main.umd.js",
  "module": "./dist/main.mjs",
  "typings": "./dist/typings/main.d.ts",
  "exports": {
    ".": {
      "import": "./dist/main.mjs",
      "types": "./dist/typings/main.d.ts",
      "require": "./dist/main.umd.js",
      "default": "./dist/main.umd.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist lib",
    "dev": "vite",
    "preview": "vite preview",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:watch": "run-p type-check \"build-only:watch {@}\" --",
    "type-check": "vue-tsc --build --force --declaration --emitDeclarationOnly",
    "build-only": "vite build",
    "build-only:watch": "vite build --watch"
  },
  "dependencies": {
    "ag-grid-community": "36.0.0-beta.20260713.1111"
  },
  "devDependencies": {
    "vue": "^3.5.32",
    "replace-in-file": "8.4.0",
    "@tsconfig/node20": "^20.1.9",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.15.3",
    "@vitejs/plugin-vue": "^5.0.5",
    "@vitejs/plugin-vue-jsx": "^4.0.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.5.1",
    "jsdom": "^24.1.0",
    "npm-run-all2": "^8.0.4",
    "typescript": "~5.8.3",
    "vite": "~5.4.19",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.7"
  },
  "peerDependencies": {
    "vue": "^3.5.32"
  },
  "publishConfig": {
    "access": "public"
  }
}
