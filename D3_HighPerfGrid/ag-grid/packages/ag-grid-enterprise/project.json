{
  "name": "ag-grid-enterprise",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/ag-grid-enterprise/src",
  "projectType": "library",
  "targets": {
    "setup": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["npx playwright install --with-deps chromium"],
        "parallel": false,
        "cwd": "packages/ag-grid-enterprise"
      }
    },
    "build": {
      "executor": "nx:noop",
      "inputs": [],
      "outputs": [],
      "dependsOn": ["build:types", "build:package", "build:copy-styles", "build:umd"]
    },
    "build:umd": {
      "executor": "@nx/esbuild:esbuild",
      "dependsOn": ["^build:package", "build:copy-styles", "build:package"],
      "inputs": [
        "tsDefaults",
        "styleOutputs",
        "charts",
        {
          "dependentTasksOutputFiles": "**/*.js",
          "transitive": true
        }
      ],
      "outputs": ["{projectRoot}/dist/ag-grid-enterprise*.js"],
      "options": {
        "outputPath": "{projectRoot}/dist",
        "deleteOutputPath": false,
        "main": "{projectRoot}/src/main-umd-styles.ts",
        "tsConfig": "{projectRoot}/tsconfig.lib.json",
        "skipTypeCheck": true,
        "esbuildConfig": "packages/ag-grid-enterprise/esbuildBuild.cjs",
        "platform": "browser",
        "target": "es2020",
        "format": ["cjs"],
        "bundle": true,
        "thirdParty": true,
        "sourcemap": false,
        "metafile": false
      },
      "configurations": {
        "production": {
          "additionalEntryPoints": ["{projectRoot}/src/main-umd-noStyles.ts"]
        },
        "staging": {
          "additionalEntryPoints": ["{projectRoot}/src/main-umd-noStyles.ts"]
        }
      },
      "cache": true
    },
    "build:umd:watch": {
      "executor": "@nx/esbuild:esbuild",
      "dependsOn": ["ag-grid-community:build:package:watch"],
      "inputs": ["tsDefaults", "styleOutputs"],
      "outputs": ["{projectRoot}/dist/ag-grid-enterprise*.js"],
      "options": {
        "outputPath": "{projectRoot}/dist",
        "deleteOutputPath": false,
        "main": "{projectRoot}/src/main-umd-styles.ts",
        "tsConfig": "{projectRoot}/tsconfig.watch.json",
        "skipTypeCheck": true,
        "esbuildConfig": "packages/ag-grid-enterprise/esbuildBuild.cjs",
        "platform": "browser",
        "target": "es2020",
        "format": ["cjs"],
        "bundle": true,
        "thirdParty": true,
        "sourcemap": false,
        "metafile": false
      },
      "configurations": {
        "watch": {}
      },
      "cache": true
    },
    "build:copy-styles": {
      "dependsOn": ["@ag-grid-community/styles:build"],
      "inputs": ["{workspaceRoot}/community-modules/styles/*.*css"],
      "outputs": ["{projectRoot}/styles/**/*"],
      "cache": false,
      "command": "rsync -r ../../community-modules/styles/*.*css --delete styles",
      "options": {
        "cwd": "packages/ag-grid-enterprise"
      }
    },
    "build:types": {
      "executor": "@nx/js:tsc",
      "dependsOn": ["^build:types", "chartsTypes"],
      "inputs": [
        "{projectRoot}/package.json",
        "{projectRoot}/src/**/*",
        "{projectRoot}/tsconfig.*.json",
        "tsDeclarations",
        "sharedGlobals",
        "defaultExcludes",
        "chartsTypes",
        {
          "externalDependencies": ["npm:typescript", "npm:esbuild"]
        }
      ],
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "packages/ag-grid-enterprise/dist/types",
        "main": "packages/ag-grid-enterprise/src/main.ts",
        "tsConfig": "packages/ag-grid-enterprise/tsconfig.types.json",
        "compiler": "tsc"
      },
      "configurations": {
        "watch": {
          "tsConfig": "packages/ag-grid-enterprise/tsconfig.types.watch.json"
        },
        "production": {}
      }
    },
    "build:package": {
      "executor": "@nx/esbuild:esbuild",
      "dependsOn": ["^build:types", "chartsPackages"],
      "inputs": [
        "{projectRoot}/package.json",
        "{projectRoot}/src/**/*",
        "{projectRoot}/tsconfig.*.json",
        "tsDeclarations",
        "sharedGlobals",
        "defaultExcludes",
        "chartsPackages",
        {
          "externalDependencies": ["npm:typescript", "npm:esbuild"]
        }
      ],
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "{projectRoot}/dist/package",
        "main": "{projectRoot}/src/main.ts",
        "tsConfig": "{projectRoot}/tsconfig.lib.json",
        "esbuildConfig": "esbuild.config.cjs",
        "external": ["ag-grid-community", "ag-stack"],
        "platform": "browser",
        "target": "es2020",
        "format": ["cjs", "esm"],
        "sourcemap": true,
        "metafile": false
      },
      "configurations": {
        "watch": {
          "tsConfig": "{projectRoot}/tsconfig.watch.json"
        },
        "staging": {
          "sourcemap": false,
          "metafile": false
        },
        "production": {
          "sourcemap": false,
          "metafile": false
        }
      }
    },
    "build:package:watch": {
      "executor": "@nx/esbuild:esbuild",
      "dependsOn": [],
      "inputs": [
        "{projectRoot}/package.json",
        "{projectRoot}/src/**/*",
        "{projectRoot}/tsconfig.*.json",
        "sharedGlobals",
        "defaultExcludes",
        {
          "externalDependencies": ["npm:esbuild"]
        }
      ],
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "{projectRoot}/dist/package",
        "deleteOutputPath": false,
        "main": "{projectRoot}/src/main.ts",
        "tsConfig": "{projectRoot}/tsconfig.watch.json",
        "skipTypeCheck": true,
        "esbuildConfig": "esbuild.config.cjs",
        "external": ["ag-grid-community", "ag-stack"],
        "platform": "browser",
        "target": "es2020",
        "format": ["cjs", "esm"],
        "sourcemap": true,
        "metafile": false
      },
      "configurations": {
        "watch": {}
      },
      "cache": true
    },
    "test:e2e": {
      "dependsOn": ["test:umd:browser", "test:umd"]
    },
    "test:umd": {
      "command": "npx vitest run --config vitest.umd.config.ts",
      "dependsOn": ["build:umd"],
      "options": {
        "cwd": "{projectRoot}"
      },
      "configurations": {
        "production": {},
        "staging": {}
      }
    },
    "test:umd:browser": {
      "executor": "nx:run-commands",
      "dependsOn": ["build:umd", "setup"],
      "options": {
        "commands": ["echo 'Skipping test:umd:browser - requires staging or production configuration'"],
        "parallel": false,
        "cwd": "packages/ag-grid-enterprise"
      },
      "configurations": {
        "production": {
          "commands": ["npx playwright test"]
        },
        "staging": {
          "commands": ["npx playwright test"]
        }
      }
    },
    "pack": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "inputs": ["allTransitiveOutputs"],
      "outputs": ["{workspaceRoot}/dist/artifacts/{projectRoot}.tgz"],
      "options": {
        "cwd": "{projectRoot}",
        "parallel": false,
        "commands": [
          "mkdir -p ../../dist/artifacts/{projectRoot}",
          "yarn pack -f ../../dist/artifacts/{projectRoot}.tgz",
          "rm -rf ../../dist/artifacts/{projectRoot}"
        ]
      }
    },
    "pack:extract": {
      "executor": "nx:run-commands",
      "dependsOn": ["pack"],
      "inputs": ["allOutputs"],
      "outputs": ["{workspaceRoot}/dist/artifacts/contents/{projectRoot}"],
      "options": {
        "command": "scripts/package/extract-contents.sh {projectRoot}"
      }
    },
    "pack:verify": {
      "executor": "nx:run-commands",
      "dependsOn": ["pack:extract"],
      "inputs": ["allOutputs"],
      "options": {
        "commands": [
          "node scripts/package/sanity-check-package.js --allowed-ext css scss -- dist/artifacts/contents/{projectRoot}/package"
        ]
      },
      "configurations": {
        "production": {},
        "archive": {}
      }
    },
    "lint:knip": {
      "command": "knip",
      "options": {
        "cwd": "{projectRoot}"
      }
    },
    "lint": {
      "dependsOn": ["lint:knip"],
      "command": "eslint && stylelint './src/**/*css'",
      "options": {
        "cwd": "{projectRoot}"
      }
    },
    "build:test": {},
    "test": {
      "command": "npx vitest run",
      "dependsOn": ["build:test"],
      "outputs": ["{workspaceRoot}/reports/ag-grid-enterprise.xml"],
      "options": {
        "cwd": "{projectRoot}"
      }
    }
  },
  "tags": ["package", "enterprise", "core"],
  "implicitDependencies": ["ag-grid-community"]
}
