        if len(record_matches) > 1:
            expected_data = [m.value for m in record_matches]
        else:
            expected_data = record_matches[0].value
{% if test.record_transform %}

        # Apply x-airbyte-record-transform to expected records (non-envelope path).
        # Runtime applies transform unconditionally — mirrors extract -> transform order.
        from jinja2 import Environment as _TEnv2, StrictUndefined as _TStrict2
        _ne_transform_env = _TEnv2(undefined=_TStrict2, autoescape=False)
        _ne_transform_map = {{ test.record_transform | tojson }}

        def _ne_apply_transform(rec):
            ctx = rec if isinstance(rec, dict) else {"value": rec}
            return {k: _ne_transform_env.from_string(v).render(record=ctx, config={}) for k, v in _ne_transform_map.items()}

        if isinstance(expected_data, list):
            expected_data = [_ne_apply_transform(r) for r in expected_data]
        else:
            expected_data = _ne_apply_transform(expected_data)
{% endif %}

        # Convert Pydantic models to dict for comparison
        if hasattr(result, 'model_dump'):
            actual_data = result.model_dump(exclude_none=True, by_alias=True)
        else:
            actual_data = result

        assert actual_data == expected_data
    else:
        # When JSONPath doesn't match, expect None
        assert result is None
{%- endif %}
