     connector_name: Snake-case connector name (e.g., "stripe")
     package_name: Full package path (e.g., "airbyte_agent_sdk.connectors.stripe")
     connector_init_lines: Pre-rendered connector initialization lines (imports + constructor)
     include_recommendation: Whether to render the progressive-tool recommendation and flow
     include_alternatives: Whether to render the legacy manual-wrapper examples
     alternatives_heading: Markdown heading used for the alternatives subsection
#}
{% macro framework_usage_blocks(
