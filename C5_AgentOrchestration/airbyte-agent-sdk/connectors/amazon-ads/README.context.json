  "replication_config": null,
  "custom_description": "Amazon Ads is Amazon's advertising platform that enables sellers and vendors to promote their\nproducts across Amazon's marketplace. This connector provides access to advertising profiles,\nportfolios, Sponsored Products campaigns (including ad groups, keywords, product ads, targets,\nand negative keywords/targets), and Sponsored Brands campaigns and ad groups for managing and\nanalyzing advertising campaigns across different marketplaces.\n",
  "supported_questions": "- List all my advertising profiles across marketplaces\n- Show me the profiles for my seller accounts\n- What marketplaces do I have advertising profiles in?\n- List all portfolios for one of my profiles\n- Show me all sponsored product campaigns\n- List all ad groups in my SP campaigns\n- Show me all keywords in my sponsored product campaigns\n- What product ads are currently running?\n- Show me all targeting clauses for my campaigns\n- List negative keywords across my ad groups\n- Show me all sponsored brands campaigns\n- List ad groups in my sponsored brands campaigns\n- What campaigns are currently enabled?\n- Find campaigns with a specific targeting type\n- Which ad groups have the highest default bid?\n- What keywords are using broad match type?",
  "unsupported_questions": "- Create a new advertising campaign\n- Update my campaign budget\n- Delete an ad group\n- Generate a performance report",
  "first_operation": {
    "method_name": "list_profiles",
    "http_method": "get",
    "path": "/v2/profiles",
    "entity": "profiles",
    "action": "list",
    "parameters": [
      {
        "name": "profileTypeFilter",
        "python_name": "profile_type_filter",
        "type": "str",
        "schema": {
          "type": "string",
          "default": "seller,vendor"
        },
        "required": null,
        "description": "Filter profiles by type. Comma-separated list of profile types.\nValid values: seller, vendor, agency\n",
        "is_deep_object": false
      }
    ],
    "params_type_name": "ProfilesListParams",
    "response_type": "ProfilesListResult",
    "description": "Returns a list of advertising profiles associated with the authenticated user.\nProfiles represent an advertiser's account in a specific marketplace. Advertisers\nmay have a single profile if they advertise in only one marketplace, or a separate\nprofile for each marketplace if they advertise regionally or globally.\n",
    "record_extractor": "$",
    "meta_extractor": null,
    "needs_envelope": true,
    "record_type": "list[Profile]",
    "meta_fields": null,
    "is_download": false
  },
