    "type_name": "GranolaAuthConfig",
    "base_name": "Granola",
    "options": [
      {
        "title": "API Key Authentication",
        "description": "",
        "fields": [
          {
            "name": "api_key",
            "type": "str",
            "required": true,
            "title": "API Key",
            "description": "Granola API key. For a personal key, open the Granola desktop app and go to Settings > Connectors > API keys > Create new key. For an Enterprise API key, go to Settings > API > Create new key. On Enterprise plans, workspace admins must enable \"Allow personal API keys\" in Settings > Workspace > General before personal keys can be created."
          }
        ],
        "type_suffix": "ApiKeyAuthentication"
      }
    ],
    "is_multi_auth": false
  },
  "replication_config": null,
  "custom_description": "The Granola API connector provides read access to meeting notes from Granola,\nan AI-powered meeting notes platform. This connector integrates with the Granola\nAPI to list and retrieve notes, including summaries, transcripts, attendees,\nand calendar event details. Requires a Granola API key.\n",
  "supported_questions": "- List all meeting notes from Granola\n- Show me recent meeting notes\n- Get the details of a specific note\n- List notes created in the last week\n- Find meeting notes from last month\n- Which meetings had the most attendees?\n- Show me notes that mention budget reviews\n- What meetings happened this quarter?",
  "unsupported_questions": "- Create a new meeting note\n- Delete a meeting note\n- Update an existing note\n- Share a note with someone",
  "first_operation": {
    "method_name": "list_notes",
    "http_method": "get",
    "path": "/v1/notes",
    "entity": "notes",
    "action": "list",
    "parameters": [
      {
        "name": "page_size",
        "python_name": "page_size",
        "type": "int",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 30,
          "default": 10
        },
        "required": false,
        "description": "Maximum number of notes to return per page",
        "is_deep_object": false
      },
      {
        "name": "cursor",
        "python_name": "cursor",
        "type": "str",
        "schema": {
          "type": "string"
        },
        "required": false,
        "description": "Pagination cursor for next page",
        "is_deep_object": false
